{
  "name": "momentum",
  "version": "0.2.2",
  "description": "Momentum - A comprehensive goals tracking management system built with React, TypeScript, and Ant Design",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/williamquintas/momentum.git"
  },
  "bugs": {
    "url": "https://github.com/williamquintas/momentum/issues"
  },
  "homepage": "https://github.com/williamquintas/momentum#readme",
  "keywords": [
    "goals",
    "tracking",
    "productivity",
    "react",
    "typescript",
    "ant-design",
    "goal-management",
    "progress-tracking",
    "habits",
    "milestones",
    "quantitative-goals",
    "qualitative-goals",
    "recurring-goals",
    "dashboard",
    "task-management"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.src.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:report": "eslint . --ext .ts,.tsx,.js,.jsx --format json --output-file eslint-report.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "type-check": "tsc --noEmit -p tsconfig.src.json",
    "type-check:watch": "tsc --noEmit --watch",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "validate:translations": "node scripts/validateTranslations.js",
    "generate:translations": "node scripts/generateTranslations.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "prepare": "husky install || true",
    "version:patch": "standard-version --release-as patch",
    "version:minor": "standard-version --release-as minor",
    "version:major": "standard-version --release-as major",
    "version:prerelease": "standard-version -s --prerelease rc",
    "version:dry-run": "standard-version --dry-run",
    "release": "npm run version:patch && git push --follow-tags origin main"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.17.9",
    "antd": "5.12.8",
    "axios": "^1.15.0",
    "country-flag-icons": "^1.6.15",
    "date-fns": "^3.0.6",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.21.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^2.1.0",
    "husky": "^8.0.3",
    "jsdom": "^23.0.1",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "sharp": "^0.34.5",
    "standard-version": "^9.5.0",
    "typescript": "5.3.3",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "lodash": "^4.17.21",
    "serialize-javascript": "^7.0.5"
  }
}
